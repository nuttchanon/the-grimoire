node_modules/

# Code-graph tool output (graphify) — commit the graph so the team shares one map (ADR 0006).
# Whitelist: commit the graph artifacts only; ignore internal/local state
# (cache, dated backups, semantic markers, analysis, cost log, per-machine python pointer).
graphify-out/*
!graphify-out/graph.json
!graphify-out/graph.html
!graphify-out/GRAPH_REPORT.md
!graphify-out/manifest.json

# Working artifacts: brainstorm specs and implementation plans are local scratch
# for the design process, not part of the published template.
docs/superpowers/

# This repo's LIVE per-run session state is never tracked.
journal/session/

# Do NOT ignore templates/journal/session/ — in this template repo the session seed
# (current.md, archive/.gitkeep) MUST be tracked so it ships via npx/npm pack and
# `grimoire init`/seedRoot can seed it. Target projects get the session ignore from
# templates/gitignore-snippet.txt, which `grimoire init` writes into their .gitignore.
